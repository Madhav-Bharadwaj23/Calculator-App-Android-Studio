<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#edf2f4"/>

    <!-- Border -->
    <stroke
        android:width="2dp"
        android:color="#CCCCCC"/>

    <!-- Rounded corners -->
    <corners android:radius="20dp"/>

    <!-- Optional padding inside -->
    <padding
        android:left="16dp"
        android:right="16dp"
        android:top="16dp"
        android:bottom="16dp"/>

</shape>